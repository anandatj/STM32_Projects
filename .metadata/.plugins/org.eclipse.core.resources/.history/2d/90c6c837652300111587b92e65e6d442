	if (htim->Instance == TIM1)
	    {
		  Freq.w = 2*PI*Freq.freq;
		  Freq.theta += Freq.w * Freq.dt/2;

		  TIM1->CCR1 = Freq.PWM_A;
		  TIM1->CCR2 = Freq.PWM_B;
